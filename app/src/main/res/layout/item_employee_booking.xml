<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:rippleColor="@android:color/transparent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_booking_item_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Status Badge -->
        <TextView
            android:id="@+id/tv_booking_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_pill_primary"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="@string/booking_status_pending"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Booking ID -->
        <TextView
            android:id="@+id/tv_booking_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="#FB-1024"
            android:textColor="@color/grey_grey"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/tv_booking_status"
            app:layout_constraintStart_toEndOf="@id/tv_booking_status"
            app:layout_constraintTop_toTopOf="@id/tv_booking_status" />

        <!-- Star Rating (Visible when collapsed) -->
        <LinearLayout
            android:id="@+id/ll_collapsed_rating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="@id/tv_booking_status"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tv_booking_status">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@android:drawable/btn_star_big_on"
                app:tint="@color/primary_color" />

            <TextView
                android:id="@+id/tv_collapsed_rating_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="0.0"
                android:textColor="@color/black"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Profile Picture -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_customer_profile"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="12dp"
            android:padding="1dp"
            android:src="@drawable/ic_launcher_background"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_booking_status"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.FadeBARBer.Rounded"
            app:strokeColor="@color/black"
            app:strokeWidth="1dp" />

        <!-- Customer Info -->
        <LinearLayout
            android:id="@+id/ll_customer_info"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="@id/iv_customer_profile"
            app:layout_constraintEnd_toStartOf="@id/iv_expand_arrow"
            app:layout_constraintStart_toEndOf="@id/iv_customer_profile"
            app:layout_constraintTop_toTopOf="@id/iv_customer_profile">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_customer_name_book"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Customer Name"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/iv_call_direct"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/ic_phone"
                    app:tint="@color/primary_color" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_booking_date_book"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="04/05/26"
                android:textColor="@color/grey_grey"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tv_booking_time_book"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10:00 AM"
                android:textColor="@color/primary_color"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Expand Arrow -->
        <ImageView
            android:id="@+id/iv_expand_arrow"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:rotation="180"
            android:src="@drawable/ic_arrow_up"
            app:layout_constraintBottom_toBottomOf="@id/iv_customer_profile"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/iv_customer_profile"
            app:tint="@color/grey_grey" />

        <!-- Expandable Content -->
        <LinearLayout
            android:id="@+id/ll_expandable_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/iv_customer_profile"
            tools:layout_editor_absoluteX="12dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="12dp"
                android:background="#EEEEEE" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Left: Hairstyle Info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.3"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="80dp"
                        android:layout_height="80dp">

                        <!-- The border and background box -->
                        <com.google.android.material.imageview.ShapeableImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="1dp"
                            android:src="@null"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.FadeBARBer.Rounded"
                            app:strokeColor="@color/black"
                            app:strokeWidth="1dp" />

                        <!-- The actual service image with pseudo padding -->
                        <ImageView
                            android:id="@+id/iv_chosen_hairstyle"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="8dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_launcher_background" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tv_hairstyle_name_book"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/style_fade"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Right: Rating & Comment -->
                <LinearLayout
                    android:id="@+id/ll_rating_info"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <RatingBar
                        android:id="@+id/rb_item_rating"
                        style="?android:attr/ratingBarStyleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:isIndicator="true"
                        android:numStars="5"
                        android:progressTint="#FFD700"
                        android:rating="0" />

                    <TextView
                        android:id="@+id/tv_item_comment"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:maxLines="3"
                        android:text="No comments"
                        android:textColor="@color/grey_grey"
                        android:textSize="12sp"
                        android:textStyle="italic" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Buttons Row -->
        <LinearLayout
            android:id="@+id/ll_buttons_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/ll_expandable_content">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cancel_booking_book"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:paddingVertical="10dp"
                android:text="@string/cancel_booking"
                android:textColor="@color/warning_red_icon"
                android:textSize="11sp"
                android:textStyle="bold"
                app:backgroundTint="#FFFFFF"
                app:cornerRadius="24dp"
                app:strokeColor="@color/warning_red_icon"
                app:strokeWidth="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_edit_booking_book"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:paddingVertical="10dp"
                android:text="@string/edit_booking"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                app:backgroundTint="@color/info_blue_icon"
                app:cornerRadius="24dp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
