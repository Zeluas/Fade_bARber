<?xml version="1.0" encoding="utf-8"?>
<!--
    Activity Booking Layout: Allows users to schedule an appointment.
    Sections:
    - Top Bar: Navigation and Title.
    - Date Picker: Calendar trigger and display.
    - Time Picker: Custom dialog trigger and display.
    - Hairstylist List: Selection of available barbers.
    - Hairstyle Preview: Link to AR Try-On activity.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cl_booking_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/back_primary_color"
    tools:context=".BookingActivity">

    <!-- Section 1: Top Bar Header -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/mcv_top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="0dp"
        app:cardElevation="0dp"
        app:cardMaxElevation="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/fl_top_bar"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:background="@drawable/bg_top_bar">

            <ImageView
                android:id="@+id/iv_back_booking"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center_vertical|start"
                android:layout_marginStart="5dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="Back"
                android:focusable="true"
                android:padding="12dp"
                android:src="@drawable/ic_back"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/tv_title_booking"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical|start"
                android:layout_marginStart="63dp"
                android:text="@string/booking_title"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Scrollable Content Section -->
    <ScrollView
        android:id="@+id/sv_booking_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/mcv_top_bar">

        <LinearLayout
            android:id="@+id/ll_booking_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Section 2: Date and Time Selection Row -->
            <LinearLayout
                android:id="@+id/ll_picker_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <!-- 2a. Date Selection Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/mcv_date_selection"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="-10dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:id="@+id/ll_date_selection_inner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Date Header -->
                        <LinearLayout
                            android:id="@+id/ll_date_header"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_booking_header"
                            android:paddingVertical="8dp">

                            <TextView
                                android:id="@+id/tv_date_header_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:text="@string/booking_header_date"
                                android:textColor="@color/white"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Date Controls -->
                        <LinearLayout
                            android:id="@+id/ll_date_picker_controls"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="20dp">

                            <TextView
                                android:id="@+id/tv_booking_date"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:background="@drawable/bg_pill_stroke"
                                android:clickable="true"
                                android:focusable="true"
                                android:gravity="center"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="4dp"
                                android:text="26/08/28"
                                android:textColor="@color/black"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:id="@+id/iv_calendar_button"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_pill_stroke"
                                android:clickable="true"
                                android:contentDescription="@string/booking_date_hint"
                                android:focusable="true"
                                android:padding="6dp"
                                android:src="@drawable/ic_calendar"
                                app:tint="@color/primary_color" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 2b. Time Selection Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/mcv_time_selection"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:id="@+id/ll_time_selection_inner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Time Header -->
                        <LinearLayout
                            android:id="@+id/ll_time_header"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_booking_header"
                            android:paddingVertical="8dp">

                            <TextView
                                android:id="@+id/tv_time_header_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:text="@string/booking_header_time"
                                android:textColor="@color/white"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Time Controls -->
                        <LinearLayout
                            android:id="@+id/ll_time_picker_controls"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clickable="true"
                            android:clipToPadding="false"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="20dp">

                            <TextView
                                android:id="@+id/tv_booking_time"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:background="@drawable/bg_pill_stroke"
                                android:clickable="true"
                                android:focusable="true"
                                android:gravity="center"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="4dp"
                                android:text="10:00 AM"
                                android:textColor="@color/black"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:id="@+id/iv_clock_button"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_pill_stroke"
                                android:clickable="true"
                                android:contentDescription="@string/booking_time_hint"
                                android:focusable="true"
                                android:padding="6dp"
                                android:src="@drawable/ic_clock"
                                app:tint="@color/primary_color" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Section 3: Hairstylist List Selection Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/mcv_hairstylist_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:id="@+id/ll_hairstylist_list_box"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Stylist List Header -->
                    <LinearLayout
                        android:id="@+id/ll_hairstylist_header"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_booking_header"
                        android:paddingVertical="8dp">

                        <TextView
                            android:id="@+id/tv_hairstylist_header_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="@string/booking_header_stylist"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Stylist 1 Selection Item -->
                    <LinearLayout
                        android:id="@+id/ll_stylist_item_1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_ripple_primary"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/iv_stylist_img_1"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:padding="2dp"
                            android:src="@drawable/ic_launcher_background"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.FadeBARBer.Rounded"
                            app:strokeColor="@color/black"
                            app:strokeWidth="1dp" />

                        <LinearLayout
                            android:id="@+id/ll_stylist_content_row_1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:id="@+id/ll_stylist_info_1"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tv_stylist_name_1"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Ahmad"
                                    android:textColor="@color/black"
                                    android:textStyle="bold" />

                                <RatingBar
                                    android:id="@+id/rb_stylist_rating_1"
                                    style="?android:attr/ratingBarStyleSmall"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:isIndicator="true"
                                    android:numStars="5"
                                    android:progressTint="#016808"
                                    android:rating="5"
                                    android:secondaryProgressTint="#016808" />

                                <TextView
                                    android:id="@+id/tv_stylist_specialty_1"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/stylist_specialty_label"
                                    android:textSize="13sp"
                                    tools:text="Specialty: Classic Fade" />

                                <TextView
                                    android:id="@+id/tv_stylist_available_1"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/stylist_availability_label"
                                    android:textSize="13sp"
                                    tools:text="Available: Mon-Sun" />
                            </LinearLayout>

                            <com.google.android.material.checkbox.MaterialCheckBox
                                android:id="@+id/cb_stylist_1"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_marginStart="8dp"
                                android:background="@null"
                                app:buttonTint="@drawable/sl_stylist_checkbox"
                                app:rippleColor="@color/trans_primary_color" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:id="@+id/v_stylist_divider_1"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="12dp"
                        android:background="#EEEEEE" />

                    <!-- Stylist 2 Selection Item -->
                    <LinearLayout
                        android:id="@+id/ll_stylist_item_2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_ripple_primary"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/iv_stylist_img_2"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:padding="2dp"
                            android:src="@drawable/ic_launcher_background"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.FadeBARBer.Rounded"
                            app:strokeColor="@color/black"
                            app:strokeWidth="1dp" />

                        <LinearLayout
                            android:id="@+id/ll_stylist_content_row_2"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:id="@+id/ll_stylist_info_2"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tv_stylist_name_2"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Ali"
                                    android:textColor="@color/black"
                                    android:textStyle="bold" />

                                <RatingBar
                                    android:id="@+id/rb_stylist_rating_2"
                                    style="?android:attr/ratingBarStyleSmall"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:isIndicator="true"
                                    android:numStars="5"
                                    android:progressTint="#016808"
                                    android:rating="4.5"
                                    android:secondaryProgressTint="#016808"
                                    android:stepSize="0.5" />

                                <TextView
                                    android:id="@+id/tv_stylist_specialty_2"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/stylist_specialty_label"
                                    android:textSize="13sp"
                                    tools:text="Specialty: Pompadour" />

                                <TextView
                                    android:id="@+id/tv_stylist_available_2"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/stylist_availability_label"
                                    android:textSize="13sp"
                                    tools:text="Available: Mon-Fri" />
                            </LinearLayout>

                            <com.google.android.material.checkbox.MaterialCheckBox
                                android:id="@+id/cb_stylist_2"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_marginStart="8dp"
                                android:background="@null"
                                app:buttonTint="@drawable/sl_stylist_checkbox"
                                app:rippleColor="@color/trans_primary_color" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:id="@+id/v_stylist_divider_2"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="12dp"
                        android:background="#EEEEEE" />

                    <!-- Stylist 3 Selection Item -->
                    <LinearLayout
                        android:id="@+id/ll_stylist_item_3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_ripple_primary"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/iv_stylist_img_3"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:padding="2dp"
                            android:src="@drawable/ic_launcher_background"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.FadeBARBer.Rounded"
                            app:strokeColor="@color/black"
                            app:strokeWidth="1dp" />

                        <LinearLayout
                            android:id="@+id/ll_stylist_content_row_3"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:id="@+id/ll_stylist_info_3"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tv_stylist_name_3"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Abu"
                                    android:textColor="@color/black"
                                    android:textStyle="bold" />

                                <RatingBar
                                    android:id="@+id/rb_stylist_rating_3"
                                    style="?android:attr/ratingBarStyleSmall"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:isIndicator="true"
                                    android:numStars="5"
                                    android:progressTint="#016808"
                                    android:rating="5"
                                    android:secondaryProgressTint="#016808" />

                                <TextView
                                    android:id="@+id/tv_stylist_specialty_3"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/stylist_specialty_label"
                                    android:textSize="13sp"
                                    tools:text="Specialty: Buzz Cut" />

                                <TextView
                                    android:id="@+id/tv_stylist_available_3"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/stylist_availability_label"
                                    android:textSize="13sp"
                                    tools:text="Available: Sat-Sun" />
                            </LinearLayout>

                            <com.google.android.material.checkbox.MaterialCheckBox
                                android:id="@+id/cb_stylist_3"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_marginStart="8dp"
                                android:background="@null"
                                app:buttonTint="@drawable/sl_stylist_checkbox"
                                app:rippleColor="@color/trans_primary_color" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section 4: Choose Hairstyle Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/mcv_choose_hairstyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:id="@+id/ll_choose_hairstyle_box"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Hairstyle Header -->
                    <LinearLayout
                        android:id="@+id/ll_choose_hairstyle_header"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_booking_header"
                        android:paddingVertical="8dp">

                        <TextView
                            android:id="@+id/tv_choose_hairstyle_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="@string/booking_header_hairstyle"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Hairstyle Content -->
                    <LinearLayout
                        android:id="@+id/ll_choose_hairstyle_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/iv_hairPreview_booking"
                            android:layout_width="120dp"
                            android:layout_height="120dp"
                            android:padding="2dp"
                            android:src="@drawable/ic_launcher_background"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.FadeBARBer.Rounded"
                            app:strokeColor="@color/black"
                            app:strokeWidth="1dp" />

                        <LinearLayout
                            android:id="@+id/ll_hairstyle_info"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_haircut_name_booking"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/haircut_name_placeholder"
                                android:textColor="@color/black"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_haircut_desc_booking"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="4dp"
                                android:text="@string/haircut_desc_default"
                                android:textColor="@color/grey_grey"
                                android:textSize="12sp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_choose_hairstyle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:paddingVertical="15dp"
                                android:text="@string/title_try_on"
                                android:textColor="@color/primary_color"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                app:backgroundTint="@color/white"
                                app:cornerRadius="24dp"
                                app:icon="@drawable/ic_photo_camera"
                                app:iconGravity="textStart"
                                app:iconTint="@color/primary_color"
                                app:rippleColor="@color/trans_primary_color"
                                app:strokeColor="@color/primary_color"
                                app:strokeWidth="2dp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Final Confirmation Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_confirm_booking"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:paddingVertical="16dp"
                android:text="@string/booking_btn_confirm"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="@color/primary_color"
                app:cornerRadius="24dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
