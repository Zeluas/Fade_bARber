<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/back_primary_color"
    tools:context=".BookingActivity">

    <!-- Top Bar -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/mcv_top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="0dp"
        app:cardElevation="0dp"
        app:cardMaxElevation="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/fl_top_bar"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:background="@drawable/bg_top_bar">

            <ImageView
                android:id="@+id/iv_back_booking"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center_vertical|start"
                android:layout_marginStart="5dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="Back"
                android:focusable="true"
                android:padding="12dp"
                android:src="@drawable/ic_back"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/tv_title_booking"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical|start"
                android:layout_marginStart="63dp"
                android:text="Book Your Cut"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/mcv_top_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Date and Time Pickers Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <!-- Pick your Date Section -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"

                    android:layout_marginEnd="-10dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_booking_header"
                            android:paddingVertical="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:text="Pick a Date"
                                android:textColor="@color/white"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/ll_date_picker_controls"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="20dp">

                            <TextView
                                android:id="@+id/tv_booking_date"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:background="@drawable/bg_pill_stroke"
                                android:clickable="true"
                                android:focusable="true"
                                android:gravity="center"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="4dp"
                                android:text="26/08/28"
                                android:textColor="@color/black"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:id="@+id/iv_calendar_button"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_pill_stroke"
                                android:clickable="true"
                                android:contentDescription="Select Date"
                                android:focusable="true"
                                android:padding="6dp"
                                android:src="@drawable/ic_calendar"
                                app:tint="@color/primary_color" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Pick your Time Section -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"

                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_booking_header"
                            android:paddingVertical="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:text="Pick a Time"
                                android:textColor="@color/white"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/ll_time_picker_controls"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clickable="true"
                            android:clipToPadding="false"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="20dp">

                            <TextView
                                android:id="@+id/tv_booking_time"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:background="@drawable/bg_pill_stroke"
                                android:clickable="true"
                                android:focusable="true"
                                android:gravity="center"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="4dp"
                                android:text="10:00 AM"
                                android:textColor="@color/black"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:id="@+id/iv_clock_button"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_pill_stroke"
                                android:clickable="true"
                                android:contentDescription="Select Time"
                                android:focusable="true"
                                android:padding="6dp"
                                android:src="@drawable/ic_clock"
                                app:tint="@color/primary_color" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Hairstylist List Box (Copied from fragment_home.xml) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/mcv_hairstylist_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:id="@+id/ll_hairstylist_list_box"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/ll_hairstylist_header"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_booking_header"
                        android:paddingVertical="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="Select your Preferred Hairstylist"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Stylist 1 -->
                    <LinearLayout
                        android:id="@+id/ll_stylist_item_1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_ripple_primary"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/iv_stylist_img_1"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:padding="2dp"
                            android:src="@drawable/ic_launcher_background"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.FadeBARBer.Rounded"
                            app:strokeColor="@color/black"
                            app:strokeWidth="1dp" />

                        <LinearLayout
                            android:id="@+id/ll_stylist_content_row_1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:id="@+id/ll_stylist_info_1"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tv_stylist_name_1"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Ahmad"
                                    android:textColor="@color/black"
                                    android:textStyle="bold" />

                                <RatingBar
                                    android:id="@+id/rb_stylist_rating_1"
                                    style="?android:attr/ratingBarStyleSmall"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:isIndicator="true"
                                    android:numStars="5"
                                    android:progressTint="#016808"
                                    android:rating="5"
                                    android:secondaryProgressTint="#016808" />

                                <TextView
                                    android:id="@+id/tv_stylist_specialty_1"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Specialty: Classic Fade"
                                    android:textSize="13sp" />

                                <TextView
                                    android:id="@+id/tv_stylist_available_1"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Available: Mon-Sun"
                                    android:textSize="13sp" />
                            </LinearLayout>

                            <com.google.android.material.checkbox.MaterialCheckBox
                                android:id="@+id/cb_stylist_1"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_marginStart="8dp"
                                app:buttonTint="@drawable/sl_stylist_checkbox"
                                app:rippleColor="@color/trans_primary_color"
                                android:background="@null" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="12dp"
                        android:background="#EEEEEE" />

                    <!-- Stylist 2 -->
                    <LinearLayout
                        android:id="@+id/ll_stylist_item_2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_ripple_primary"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/iv_stylist_img_2"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:padding="2dp"
                            android:src="@drawable/ic_launcher_background"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.FadeBARBer.Rounded"
                            app:strokeColor="@color/black"
                            app:strokeWidth="1dp" />

                        <LinearLayout
                            android:id="@+id/ll_stylist_content_row_2"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:id="@+id/ll_stylist_info_2"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tv_stylist_name_2"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Ali"
                                    android:textColor="@color/black"
                                    android:textStyle="bold" />

                                <RatingBar
                                    android:id="@+id/rb_stylist_rating_2"
                                    style="?android:attr/ratingBarStyleSmall"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:isIndicator="true"
                                    android:numStars="5"
                                    android:progressTint="#016808"
                                    android:rating="4.5"
                                    android:secondaryProgressTint="#016808"
                                    android:stepSize="0.5" />

                                <TextView
                                    android:id="@+id/tv_stylist_specialty_2"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Specialty: Pompadour"
                                    android:textSize="13sp" />

                                <TextView
                                    android:id="@+id/tv_stylist_available_2"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Available: Mon-Fri"
                                    android:textSize="13sp" />
                            </LinearLayout>

                            <com.google.android.material.checkbox.MaterialCheckBox
                                android:id="@+id/cb_stylist_2"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_marginStart="8dp"
                                app:buttonTint="@drawable/sl_stylist_checkbox"
                                app:rippleColor="@color/trans_primary_color"
                                android:background="@null" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="12dp"
                        android:background="#EEEEEE" />

                    <!-- Stylist 3 -->
                    <LinearLayout
                        android:id="@+id/ll_stylist_item_3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_ripple_primary"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/iv_stylist_img_3"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:padding="2dp"
                            android:src="@drawable/ic_launcher_background"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.FadeBARBer.Rounded"
                            app:strokeColor="@color/black"
                            app:strokeWidth="1dp" />

                        <LinearLayout
                            android:id="@+id/ll_stylist_content_row_3"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:id="@+id/ll_stylist_info_3"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tv_stylist_name_3"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Abu"
                                    android:textColor="@color/black"
                                    android:textStyle="bold" />

                                <RatingBar
                                    android:id="@+id/rb_stylist_rating_3"
                                    style="?android:attr/ratingBarStyleSmall"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:isIndicator="true"
                                    android:numStars="5"
                                    android:progressTint="#016808"
                                    android:rating="5"
                                    android:secondaryProgressTint="#016808" />

                                <TextView
                                    android:id="@+id/tv_stylist_specialty_3"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Specialty: Buzz Cut"
                                    android:textSize="13sp" />

                                <TextView
                                    android:id="@+id/tv_stylist_available_3"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Available: Sat-Sun"
                                    android:textSize="13sp" />
                            </LinearLayout>

                            <com.google.android.material.checkbox.MaterialCheckBox
                                android:id="@+id/cb_stylist_3"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_marginStart="8dp"
                                app:buttonTint="@drawable/sl_stylist_checkbox"
                                app:rippleColor="@color/trans_primary_color"
                                android:background="@null" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Choose Hairstyle Box -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/mcv_choose_hairstyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:id="@+id/ll_choose_hairstyle_box"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/ll_choose_hairstyle_header"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_booking_header"
                        android:paddingVertical="8dp">

                        <TextView
                            android:id="@+id/tv_choose_hairstyle_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="Choose your Hairstyle"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/ll_choose_hairstyle_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/iv_hairPreview_booking"
                            android:layout_width="120dp"
                            android:layout_height="120dp"
                            android:padding="2dp"
                            android:src="@drawable/ic_launcher_background"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.FadeBARBer.Rounded"
                            app:strokeColor="@color/black"
                            app:strokeWidth="1dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_haircut_name_booking"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="HairCut Name"
                                android:textColor="@color/black"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_haircut_desc_booking"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="4dp"
                                android:text="Description of the selected hairstyle"
                                android:textColor="@color/grey_grey"
                                android:textSize="12sp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_choose_hairstyle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:paddingVertical="15dp"
                                android:text="Try-On"
                                android:textColor="@color/primary_color"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                app:backgroundTint="@color/white"
                                app:cornerRadius="24dp"
                                app:icon="@drawable/ic_photo_camera"
                                app:iconGravity="textStart"
                                app:iconTint="@color/primary_color"
                                app:rippleColor="@color/trans_primary_color"
                                app:strokeColor="@color/primary_color"
                                app:strokeWidth="2dp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_confirm_booking"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:paddingVertical="16dp"
                android:text="Confirm Booking"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="@color/primary_color"
                app:cornerRadius="24dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>