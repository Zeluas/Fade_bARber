<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="4dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <TextView
            android:id="@+id/tv_transaction_booking_id"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:textColor="@color/primary_color"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="#BK12345" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_transaction_icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_cash"
            app:layout_constraintBottom_toBottomOf="@+id/tv_transaction_amount"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tv_transaction_amount"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.FadeBARBer.Rounded"
            app:tint="@color/primary_color" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/mcv_title_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            app:cardBackgroundColor="@color/primary_color"
            app:cardCornerRadius="4dp"
            app:cardElevation="0dp"
            app:layout_constraintStart_toEndOf="@id/iv_transaction_icon"
            app:layout_constraintTop_toTopOf="@id/iv_transaction_icon">

            <TextView
                android:id="@+id/tv_transaction_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="Customer Name" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tv_transaction_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/grey_grey"
            android:textSize="12sp"
            app:layout_constraintEnd_toStartOf="@+id/tv_transaction_amount"
            app:layout_constraintStart_toStartOf="@id/mcv_title_container"
            app:layout_constraintTop_toBottomOf="@id/mcv_title_container"
            tools:text="Hairstyle Name • Barber Name" />

        <TextView
            android:id="@+id/tv_transaction_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/primary_color"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/mcv_title_container"
            app:layout_constraintTop_toBottomOf="@id/tv_transaction_subtitle"
            tools:text="12/05/24" />

        <TextView
            android:id="@+id/tv_transaction_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textColor="@color/grey_grey"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/tv_transaction_date"
            app:layout_constraintStart_toEndOf="@id/tv_transaction_date"
            app:layout_constraintTop_toTopOf="@id/tv_transaction_date"
            tools:text="10:30 AM" />

        <TextView
            android:id="@+id/tv_transaction_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/success_green_icon"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_transaction_booking_id"
            tools:text="+RM 25.00" />

        <TextView
            android:id="@+id/tv_transaction_method"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/grey_grey"
            android:textSize="10sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_transaction_amount"
            tools:text="Cash" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
