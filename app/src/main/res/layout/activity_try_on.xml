<?xml version="1.0" encoding="utf-8"?>
<!--
    Activity Try-On Layout: Features a CameraX preview and a hairstyle carousel.
    Optimized: Reduced nesting in the bottom sheet and localized all strings.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layout_try_on_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    tools:context=".TryOnActivity">

    <!-- DeepAR Rendering Surface -->
    <SurfaceView
        android:id="@+id/surfaceView"
        android:layout_width="match_parent"
        android:layout_height="512dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Top Navigation Bar -->
    <View
        android:id="@+id/view_top_bar_overlay"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#80000000"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="5dp"
        android:layout_marginTop="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/plus_button_description"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white" />

    <TextView
        android:id="@+id/tv_try_on_title"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginStart="10dp"
        android:gravity="center"
        android:text="@string/title_try_on"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/btn_back"
        app:layout_constraintStart_toEndOf="@id/btn_back"
        app:layout_constraintTop_toTopOf="@id/btn_back" />

    <!-- Bottom Controls Section -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottom_sheet_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Hidden label that appears when carousel is collapsed -->
        <TextView
            android:id="@+id/tv_choose_hairstyle_collapsed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:alpha="0"
            android:text="@string/choose_your_hairstyle"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/carousel_container"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Floating Capture Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/fab_capture"
            style="@style/Widget.MaterialComponents.Button.Icon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="16dp"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            android:tooltipText="@string/try_on_capture_tooltip"
            app:backgroundTint="@color/primary_color"
            app:icon="@drawable/ic_photo_camera"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="32dp"
            app:iconTint="@color/white"
            app:layout_constraintBottom_toTopOf="@id/carousel_container"
            app:layout_constraintEnd_toEndOf="parent"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.FadeBARBer.FAB.Circle"
            app:strokeColor="@color/black"
            app:strokeWidth="0.7dp" />

        <!-- Carousel Container with Expand/Collapse logic -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/carousel_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_carousel"
            android:paddingTop="8dp"
            android:paddingBottom="12dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/iv_carousel_arrow"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:padding="8dp"
                android:rotation="180"
                android:scaleX="1.6"
                android:scaleY="1.6"
                android:src="@drawable/ic_arrow_up"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <HorizontalScrollView
                android:id="@+id/carousel_scroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:clipToPadding="false"
                android:paddingStart="16dp"
                android:paddingEnd="4dp"
                android:scrollbars="none"
                app:layout_constraintTop_toBottomOf="@id/iv_carousel_arrow">

                <LinearLayout
                    android:id="@+id/ll_carousel_items"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Hairstyle Item: Buzz Cut -->
                    <LinearLayout
                        android:id="@+id/item_buzz_cut"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:gravity="center"
                        android:orientation="vertical">

                        <View
                            android:id="@+id/v_icon_buzz_cut"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:background="@drawable/bg_carousel_item" />

                        <TextView
                            android:id="@+id/tv_label_buzz_cut"
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/style_buzz_cut"
                            android:textAlignment="center"
                            android:textColor="@color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Hairstyle Item: Fade -->
                    <LinearLayout
                        android:id="@+id/item_fade"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:gravity="center"
                        android:orientation="vertical">

                        <View
                            android:id="@+id/v_icon_fade"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:background="@drawable/bg_carousel_item" />

                        <TextView
                            android:id="@+id/tv_label_fade"
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/style_fade"
                            android:textAlignment="center"
                            android:textColor="@color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Hairstyle Item: Pompadour -->
                    <LinearLayout
                        android:id="@+id/item_pompadour"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:gravity="center"
                        android:orientation="vertical">

                        <View
                            android:id="@+id/v_icon_pompadour"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:background="@drawable/bg_carousel_item" />

                        <TextView
                            android:id="@+id/tv_label_pompadour"
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/style_pompadour"
                            android:textAlignment="center"
                            android:textColor="@color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Hairstyle Item: Undercut -->
                    <LinearLayout
                        android:id="@+id/item_undercut"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:gravity="center"
                        android:orientation="vertical">

                        <View
                            android:id="@+id/v_icon_undercut"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:background="@drawable/bg_carousel_item" />

                        <TextView
                            android:id="@+id/tv_label_undercut"
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/style_undercut"
                            android:textAlignment="center"
                            android:textColor="@color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Hairstyle Item: Crew Cut -->
                    <LinearLayout
                        android:id="@+id/item_crew_cut"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:gravity="center"
                        android:orientation="vertical">

                        <View
                            android:id="@+id/v_icon_crew_cut"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:background="@drawable/bg_carousel_item" />

                        <TextView
                            android:id="@+id/tv_label_crew_cut"
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/style_crew_cut"
                            android:textAlignment="center"
                            android:textColor="@color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Hairstyle Item: Mohawk -->
                    <LinearLayout
                        android:id="@+id/item_mohawk"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:gravity="center"
                        android:orientation="vertical">

                        <View
                            android:id="@+id/v_icon_mohawk"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:background="@drawable/bg_carousel_item" />

                        <TextView
                            android:id="@+id/tv_label_mohawk"
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/style_mohawk"
                            android:textAlignment="center"
                            android:textColor="@color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Hairstyle Item: Side Part -->
                    <LinearLayout
                        android:id="@+id/item_side_part"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:gravity="center"
                        android:orientation="vertical">

                        <View
                            android:id="@+id/v_icon_side_part"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:background="@drawable/bg_carousel_item" />

                        <TextView
                            android:id="@+id/tv_label_side_part"
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/style_side_part"
                            android:textAlignment="center"
                            android:textColor="@color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Hairstyle Item: Top Knot -->
                    <LinearLayout
                        android:id="@+id/item_top_knot"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:gravity="center"
                        android:orientation="vertical">

                        <View
                            android:id="@+id/v_icon_top_knot"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:background="@drawable/bg_carousel_item" />

                        <TextView
                            android:id="@+id/tv_label_top_knot"
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/style_top_knot"
                            android:textAlignment="center"
                            android:textColor="@color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:id="@+id/tv_choose_hairstyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/choose_your_hairstyle"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/carousel_scroll" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
