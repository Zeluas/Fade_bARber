<?xml version="1.0" encoding="utf-8"?>
<!--
    Activity Try-On Layout: Features a CameraX preview and a hairstyle carousel.
    Optimized: Reduced nesting in the bottom sheet and localized all strings.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layout_try_on_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    tools:context=".TryOnActivity">

    <!-- DeepAR Rendering Surface -->
    <SurfaceView
        android:id="@+id/surfaceView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Frozen Image Preview -->
    <ImageView
        android:id="@+id/iv_captured_preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black"
        android:scaleType="centerInside"
        android:visibility="gone" />

    <!-- Flash Overlay -->
    <View
        android:id="@+id/v_flash"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        android:background="#808080"
        android:visibility="gone" />

    <!-- Top Navigation Bar -->
    <View
        android:id="@+id/view_top_bar_overlay"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#80000000"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="5dp"
        android:layout_marginTop="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/plus_button_description"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white" />

    <TextView
        android:id="@+id/tv_try_on_title"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginStart="10dp"
        android:gravity="center"
        android:text="@string/title_try_on"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/btn_back"
        app:layout_constraintStart_toEndOf="@id/btn_back"
        app:layout_constraintTop_toTopOf="@id/btn_back" />

    <!-- Bottom Controls Section -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottom_sheet_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Hidden label that appears when carousel is collapsed -->
        <TextView
            android:id="@+id/tv_choose_hairstyle_collapsed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:alpha="0"
            android:text="@string/choose_your_hairstyle"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/carousel_container"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Floating Capture Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/fab_capture"
            style="@style/Widget.MaterialComponents.Button.Icon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="16dp"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            android:tooltipText="@string/try_on_capture_tooltip"
            app:backgroundTint="@color/primary_color"
            app:icon="@drawable/ic_photo_camera"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="32dp"
            app:iconTint="@color/white"
            app:layout_constraintBottom_toTopOf="@id/carousel_container"
            app:layout_constraintEnd_toEndOf="parent"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.FadeBARBer.FAB.Circle"
            app:strokeColor="@color/black"
            app:strokeWidth="0.7dp" />

        <!-- Carousel Container with Expand/Collapse logic -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/carousel_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_carousel"
            android:paddingTop="8dp"
            android:paddingBottom="12dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/iv_carousel_arrow"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:padding="8dp"
                android:rotation="180"
                android:scaleX="1.6"
                android:scaleY="1.6"
                android:src="@drawable/ic_arrow_up"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <HorizontalScrollView
                android:id="@+id/carousel_scroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:clipToPadding="false"
                android:paddingStart="16dp"
                android:paddingEnd="4dp"
                android:scrollbars="none"
                app:layout_constraintTop_toBottomOf="@id/iv_carousel_arrow">

                <LinearLayout
                    android:id="@+id/ll_carousel_items"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Hairstyle Item: Brazilian -->
                    <LinearLayout
                        android:id="@+id/item_brazilian"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:gravity="center"
                        android:orientation="vertical">

                        <FrameLayout
                            android:id="@+id/v_icon_brazilian"
                            android:layout_width="80dp"
                            android:layout_height="80dp">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_carousel_item" />
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="12dp"
                                android:src="@drawable/ic_hair"
                                app:tint="@color/white" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tv_label_brazilian"
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/style_brazilian"
                            android:textAlignment="center"
                            android:textColor="@color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Hairstyle Item: Bird Hair -->
                    <LinearLayout
                        android:id="@+id/item_bird_hair"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:gravity="center"
                        android:orientation="vertical">

                        <FrameLayout
                            android:id="@+id/v_icon_bird_hair"
                            android:layout_width="80dp"
                            android:layout_height="80dp">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_carousel_item" />
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="12dp"
                                android:src="@drawable/ic_hair"
                                app:tint="@color/white" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tv_label_bird_hair"
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/style_bird_hair"
                            android:textAlignment="center"
                            android:textColor="@color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Hairstyle Item: Side Sweep -->
                    <LinearLayout
                        android:id="@+id/item_side_sweep"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:gravity="center"
                        android:orientation="vertical">

                        <FrameLayout
                            android:id="@+id/v_icon_side_sweep"
                            android:layout_width="80dp"
                            android:layout_height="80dp">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_carousel_item" />
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="12dp"
                                android:src="@drawable/ic_hair"
                                app:tint="@color/white" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tv_label_side_sweep"
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/style_side_sweep"
                            android:textAlignment="center"
                            android:textColor="@color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Hairstyle Item: Wolf Hair -->
                    <LinearLayout
                        android:id="@+id/item_wolf_hair"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:gravity="center"
                        android:orientation="vertical">

                        <FrameLayout
                            android:id="@+id/v_icon_wolf_hair"
                            android:layout_width="80dp"
                            android:layout_height="80dp">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_carousel_item" />
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="12dp"
                                android:src="@drawable/ic_hair"
                                app:tint="@color/white" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tv_label_wolf_hair"
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/style_wolf_hair"
                            android:textAlignment="center"
                            android:textColor="@color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Hairstyle Item: 70s Afro -->
                    <LinearLayout
                        android:id="@+id/item_70s_afro"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:gravity="center"
                        android:orientation="vertical">

                        <FrameLayout
                            android:id="@+id/v_icon_70s_afro"
                            android:layout_width="80dp"
                            android:layout_height="80dp">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_carousel_item" />
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="12dp"
                                android:src="@drawable/ic_hair"
                                app:tint="@color/white" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tv_label_70s_afro"
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/style_70s_afro"
                            android:textAlignment="center"
                            android:textColor="@color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Hairstyle Item: Curtain -->
                    <LinearLayout
                        android:id="@+id/item_curtain"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:gravity="center"
                        android:orientation="vertical">

                        <FrameLayout
                            android:id="@+id/v_icon_curtain"
                            android:layout_width="80dp"
                            android:layout_height="80dp">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_carousel_item" />
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="12dp"
                                android:src="@drawable/ic_hair"
                                app:tint="@color/white" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tv_label_curtain"
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/style_curtain"
                            android:textAlignment="center"
                            android:textColor="@color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Hairstyle Item: Disconnect Undercut -->
                    <LinearLayout
                        android:id="@+id/item_disconnect_undercut"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:gravity="center"
                        android:orientation="vertical">

                        <FrameLayout
                            android:id="@+id/v_icon_disconnect_undercut"
                            android:layout_width="80dp"
                            android:layout_height="80dp">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_carousel_item" />
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="12dp"
                                android:src="@drawable/ic_hair"
                                app:tint="@color/white" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tv_label_disconnect_undercut"
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/style_disconnect_undercut"
                            android:textAlignment="center"
                            android:textColor="@color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Hairstyle Item: Afro Tapper -->
                    <LinearLayout
                        android:id="@+id/item_afro_tapper"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:gravity="center"
                        android:orientation="vertical">

                        <FrameLayout
                            android:id="@+id/v_icon_afro_tapper"
                            android:layout_width="80dp"
                            android:layout_height="80dp">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_carousel_item" />
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="12dp"
                                android:src="@drawable/ic_hair"
                                app:tint="@color/white" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tv_label_afro_tapper"
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/style_afro_tapper"
                            android:textAlignment="center"
                            android:textColor="@color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Hairstyle Item: Punk -->
                    <LinearLayout
                        android:id="@+id/item_punk"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:gravity="center"
                        android:orientation="vertical">

                        <FrameLayout
                            android:id="@+id/v_icon_punk"
                            android:layout_width="80dp"
                            android:layout_height="80dp">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_carousel_item" />
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="12dp"
                                android:src="@drawable/ic_hair"
                                app:tint="@color/white" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tv_label_punk"
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/style_punk"
                            android:textAlignment="center"
                            android:textColor="@color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Hairstyle Item: Viking Helmet (Test) -->
                    <LinearLayout
                        android:id="@+id/item_viking_helmet"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:gravity="center"
                        android:orientation="vertical">

                        <FrameLayout
                            android:id="@+id/v_icon_viking_helmet"
                            android:layout_width="80dp"
                            android:layout_height="80dp">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_carousel_item" />
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="12dp"
                                android:src="@drawable/ic_hair"
                                app:tint="@color/white" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tv_label_viking_helmet"
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/style_viking_helmet"
                            android:textAlignment="center"
                            android:textColor="@color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Hairstyle Item: Vendetta Mask (Test) -->
                    <LinearLayout
                        android:id="@+id/item_vendetta_mask"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:gravity="center"
                        android:orientation="vertical">

                        <FrameLayout
                            android:id="@+id/v_icon_vendetta_mask"
                            android:layout_width="80dp"
                            android:layout_height="80dp">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_carousel_item" />
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="12dp"
                                android:src="@drawable/ic_hair"
                                app:tint="@color/white" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tv_label_vendetta_mask"
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/style_vendetta_mask"
                            android:textAlignment="center"
                            android:textColor="@color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:id="@+id/tv_choose_hairstyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/choose_your_hairstyle"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/carousel_scroll" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Post-Capture Controls -->
    <LinearLayout
        android:id="@+id/layout_post_capture"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:orientation="horizontal"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel"
            style="@style/Widget.MaterialComponents.Button.Icon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginEnd="32dp"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            app:backgroundTint="@color/warning_red_icon"
            app:icon="@drawable/ic_cancel"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="32dp"
            app:iconTint="@color/white"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.FadeBARBer.FAB.Circle"
            app:strokeColor="@color/black"
            app:strokeWidth="0.7dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save"
            style="@style/Widget.MaterialComponents.Button.Icon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            android:layout_marginLeft="60dp"
            app:backgroundTint="@color/primary_color"
            app:icon="@drawable/ic_check_circle"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="32dp"
            app:iconTint="@color/white"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.FadeBARBer.FAB.Circle"
            app:strokeColor="@color/black"
            app:strokeWidth="0.7dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
