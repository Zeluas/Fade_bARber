<?xml version="1.0" encoding="utf-8"?>
<!--
    Activity Auth Layout: Handles Login and multi-step Signup flows.
    Optimized: Reduced nesting using ConstraintLayout and localized strings.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layout_auth_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/trans_primary_color"
    android:clipChildren="false"
    android:clipToPadding="false"
    tools:context=".AuthActivity">

    <!-- Section 1: Top Branding Header (Logo and Title) -->
    <LinearLayout
        android:id="@+id/ll_auth_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@+id/mcv_auth_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_auth_logo"
            android:layout_width="62dp"
            android:layout_height="62dp"
            android:contentDescription="App Logo"
            android:src="@mipmap/ic_launcher" />

        <TextView
            android:id="@+id/tv_auth_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="@string/auth_title"
            android:textColor="@color/black"
            android:textSize="28sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Section 2: Main Authentication Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/mcv_auth_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:layout_constraintBottom_toTopOf="@+id/btn_switch_auth_mode"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.6"
        app:strokeColor="@color/primary_color"
        app:strokeWidth="2dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_card_root"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- 2a. Card Header Section -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_auth_header_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/primary_color"
                app:layout_constraintTop_toTopOf="parent">

                <!-- Dynamic Background: Floating Bubbles -->
                <com.zejyv.azizul.uitm.fadebarber.FloatingBubblesView
                    android:id="@+id/floating_bubbles"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Overlay to dim the bubble background -->
                <View
                    android:id="@+id/view_header_overlay"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:background="#5E000000"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Navigation and Title Row -->
                <ImageView
                    android:id="@+id/iv_auth_back"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_margin="10dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="8dp"
                    android:src="@drawable/ic_back"
                    android:visibility="invisible"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/white" />

                <LinearLayout
                    android:id="@+id/ll_title_indicator_group"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingVertical="20dp"
                    android:gravity="center"
                    android:orientation="horizontal"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:id="@+id/tv_form_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auth_login_title"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/ll_step_indicator"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:orientation="horizontal"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <TextView
                            android:id="@+id/tv_step_bracket_open"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="("
                            android:textColor="@color/white"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_step_number"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1"
                            android:textColor="@color/white"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_step_bracket_close"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="/3)"
                            android:textColor="@color/white"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 2b. Forms and Action Section -->
            <FrameLayout
                android:id="@+id/fl_form_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:minHeight="150dp"
                app:layout_constraintTop_toBottomOf="@id/layout_auth_header_container">

                <!-- Login Form Section -->
                <LinearLayout
                    android:id="@+id/ll_login_step"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <TextView
                        android:id="@+id/tv_login_email_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginBottom="4dp"
                        android:text="@string/login_email_label"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/et_login_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/bg_pill_stroke"
                        android:gravity="center_vertical|start"
                        android:hint="@string/login_email_label"
                        android:imeOptions="actionNext"
                        android:inputType="textEmailAddress"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="12dp"
                        android:textColor="@color/black"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_login_password_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginBottom="4dp"
                        android:text="@string/login_password_label"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/et_login_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_pill_stroke"
                        android:gravity="center_vertical|start"
                        android:hint="@string/login_password_label"
                        android:imeOptions="actionDone"
                        android:inputType="textPassword"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="12dp"
                        android:textColor="@color/black"
                        android:textStyle="bold" />

                    <CheckBox
                        android:id="@+id/cb_remember_me"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="start"
                        android:layout_marginStart="4dp"
                        android:buttonTint="@color/primary_color"
                        android:scaleX="1.1"
                        android:scaleY="1.1"
                        android:text="@string/login_remember_me"
                        android:textSize="16sp" />
                </LinearLayout>

                <!-- Signup Step 1: Account Identification -->
                <LinearLayout
                    android:id="@+id/ll_signup_step_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tv_signup_step1_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginBottom="12dp"
                        android:text="@string/signup_step1_desc"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tv_signup_email_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginBottom="4dp"
                        android:text="@string/signup_email_label"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/et_signup_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:background="@drawable/bg_pill_stroke"
                        android:gravity="center_vertical|start"
                        android:hint="@string/signup_email_label"
                        android:imeOptions="actionNext"
                        android:inputType="textEmailAddress"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="12dp"
                        android:textColor="@color/black"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_signup_username_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginBottom="4dp"
                        android:text="@string/signup_username_label"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/et_signup_username"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_pill_stroke"
                        android:gravity="center_vertical|start"
                        android:hint="@string/signup_username_label"
                        android:imeOptions="actionDone"
                        android:inputType="text"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="12dp"
                        android:textColor="@color/black"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Signup Step 2: Personal Identity -->
                <LinearLayout
                    android:id="@+id/ll_signup_step_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tv_signup_step2_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginBottom="12dp"
                        android:text="@string/signup_step2_desc"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tv_signup_name_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginBottom="4dp"
                        android:text="@string/signup_name_label"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/et_signup_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:background="@drawable/bg_pill_stroke"
                        android:gravity="center_vertical|start"
                        android:hint="@string/signup_name_label"
                        android:imeOptions="actionNext"
                        android:inputType="textPersonName"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="12dp"
                        android:textColor="@color/black"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_signup_phone_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginBottom="4dp"
                        android:text="@string/signup_phone_label"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/et_signup_phone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_pill_stroke"
                        android:gravity="center_vertical|start"
                        android:hint="@string/signup_phone_label"
                        android:imeOptions="actionDone"
                        android:inputType="phone"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="12dp"
                        android:textColor="@color/black"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Signup Step 3: Security & Credentials -->
                <LinearLayout
                    android:id="@+id/ll_signup_step_3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tv_signup_step3_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginBottom="12dp"
                        android:text="@string/signup_step3_desc"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tv_signup_password_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginBottom="4dp"
                        android:text="@string/signup_password_label"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/et_signup_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:background="@drawable/bg_pill_stroke"
                        android:gravity="center_vertical|start"
                        android:hint="@string/signup_password_label"
                        android:imeOptions="actionNext"
                        android:inputType="textPassword"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="12dp"
                        android:textColor="@color/black"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_signup_confirm_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginBottom="4dp"
                        android:text="@string/signup_confirm_password_label"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/et_signup_confirm"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_pill_stroke"
                        android:gravity="center_vertical|start"
                        android:hint="@string/signup_confirm_password_label"
                        android:imeOptions="actionDone"
                        android:inputType="textPassword"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="12dp"
                        android:textColor="@color/black"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Success State View -->
                <LinearLayout
                    android:id="@+id/ll_signup_success"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/iv_signup_success_icon"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/bg_ic_circular"
                        android:backgroundTint="@color/success_green"
                        android:padding="12dp"
                        android:src="@drawable/ic_check_circle"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.FadeBARBer.FAB.Circle"
                        app:tint="@color/success_green_icon" />

                    <TextView
                        android:id="@+id/tv_signup_success_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/signup_success_title"
                        android:textColor="@color/success_green_icon"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_signup_success_msg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="@string/signup_success_msg"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Error State View -->
                <LinearLayout
                    android:id="@+id/ll_signup_failed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/iv_signup_failed_icon"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/bg_ic_circular"
                        android:backgroundTint="@color/warning_red"
                        android:padding="8dp"
                        android:src="@drawable/ic_warning_circle"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.FadeBARBer.FAB.Circle"
                        app:tint="@color/warning_red_icon" />

                    <TextView
                        android:id="@+id/tv_signup_failed_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auth_failed_title"
                        android:textColor="@color/warning_red_icon"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_signup_error_details"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_error_details"
                        android:fontFamily="monospace"
                        android:gravity="start"
                        android:minHeight="100dp"
                        android:padding="12sp"
                        android:text="@string/signup_error_default_msg"
                        android:textColor="@color/black"
                        android:textSize="12sp"
                        android:visibility="gone" />
                </LinearLayout>
            </FrameLayout>

            <!-- Primary Action Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_auth_action"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"
                android:backgroundTint="@color/primary_color"
                android:text="@string/login_btn_text"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="24dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@id/fl_form_content" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Section 3: Bottom Mode Switcher -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_switch_auth_mode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="32dp"
        android:paddingVertical="15dp"
        android:text="@string/login_switch_to_signup"
        android:textColor="@color/primary_color"
        android:textSize="13sp"
        android:textStyle="bold"
        app:backgroundTint="@color/white"
        app:cornerRadius="24dp"
        app:rippleColor="@color/trans_primary_color"
        app:strokeColor="@color/primary_color"
        app:strokeWidth="2dp"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Section 4: Exit Confirmation Dialog -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_exit_confirmation"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B3000000"
        android:clickable="true"
        android:elevation="20dp"
        android:focusable="true"
        android:visibility="gone">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/mcv_exit_dialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="40dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:strokeColor="@color/primary_color"
            app:strokeWidth="2dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Exit Dialog Header -->
                <TextView
                    android:id="@+id/tv_exit_dialog_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/primary_color"
                    android:gravity="center"
                    android:padding="16dp"
                    android:text="@string/exit_dialog_title"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Exit Dialog Body -->
                <TextView
                    android:id="@+id/tv_exit_dialog_msg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center"
                    android:text="@string/exit_dialog_msg"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_exit_dialog_title" />

                <!-- Buttons Row -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_exit_cancel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginEnd="8dp"
                    android:layout_marginBottom="24dp"
                    android:paddingVertical="12dp"
                    android:text="@string/exit_dialog_btn_cancel"
                    android:textColor="@color/primary_color"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/white"
                    app:cornerRadius="24dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/btn_exit_confirm"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_exit_dialog_msg"
                    app:rippleColor="@color/trans_primary_color"
                    app:strokeColor="@color/primary_color"
                    app:strokeWidth="2dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_exit_confirm"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="24dp"
                    android:backgroundTint="@color/warning_red_icon"
                    android:paddingVertical="12dp"
                    android:text="@string/exit_dialog_btn_confirm"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:cornerRadius="24dp"
                    app:layout_constraintBottom_toBottomOf="@id/btn_exit_cancel"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/btn_exit_cancel"
                    app:layout_constraintTop_toTopOf="@id/btn_exit_cancel" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
