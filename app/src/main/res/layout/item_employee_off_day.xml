<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/primary_color"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Profile Avatar -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/iv_item_profile_image"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginEnd="12dp"
                android:background="@color/white"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.FadeBARBer.Rounded"
                app:strokeColor="@color/black"
                app:strokeWidth="1dp"
                tools:src="@drawable/ic_profile" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_item_employee_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Employee Name"
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_item_status_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_vote_accept_badge"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:text="APPROVED"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:visibility="gone"
                        tools:visibility="visible" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_item_employee_username"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="\@shortname"
                    android:textColor="@color/primary_color"
                    android:textSize="12sp"
                    android:textStyle="italic" />

                <TextView
                    android:id="@+id/tv_item_employee_uid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="UID: xxxxxxxx"
                    android:textColor="@color/grey_grey"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_item_off_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="04/05/26"
                android:textColor="@color/primary_color"
                android:textStyle="bold"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" | "
                android:textColor="@color/grey_grey"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_item_off_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="08:00 AM - 05:00 PM"
                android:textColor="@color/grey_grey"
                android:textSize="14sp" />
        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Reason"
            app:hintTextColor="@color/primary_color"
            app:boxStrokeColor="@color/primary_color">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_item_off_reason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="false"
                android:cursorVisible="false"
                android:focusable="false"
                android:gravity="top"
                android:inputType="textMultiLine|textNoSuggestions"
                android:maxLines="4"
                android:minLines="3"
                android:textColor="@color/black"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_vote_accept_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_vote_accept_badge"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="0 Accept"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_vote_decline_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_vote_decline_badge"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="0 Decline"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="@color/back_primary_color" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical|end"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/ll_vote_actions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone"
                tools:visibility="visible">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_vote_accept"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:backgroundTint="@color/primary_color"
                    android:text="Accept"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    app:cornerRadius="8dp"
                    app:icon="@drawable/ic_check_circle"
                    app:iconTint="@color/white"
                    app:iconSize="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_vote_decline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#F44336"
                    android:text="Decline"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    app:cornerRadius="8dp"
                    app:icon="@drawable/ic_cancel"
                    app:iconTint="@color/white"
                    app:iconSize="16dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_user_vote_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="You Accepted"
                android:textColor="#4CAF50"
                android:textStyle="bold"
                android:textSize="12sp"
                android:visibility="gone"
                tools:visibility="visible" />

            <LinearLayout
                android:id="@+id/ll_admin_actions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone"
                tools:visibility="visible">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_admin_approve"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:backgroundTint="@color/primary_color"
                    android:text="Approve"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    app:cornerRadius="8dp"
                    app:icon="@drawable/ic_check_circle"
                    app:iconTint="@color/white"
                    app:iconSize="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_admin_reject"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#F44336"
                    android:text="Reject"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    app:cornerRadius="8dp"
                    app:icon="@drawable/ic_cancel"
                    app:iconTint="@color/white"
                    app:iconSize="16dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
