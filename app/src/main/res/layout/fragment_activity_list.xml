<?xml version="1.0" encoding="utf-8"?>
<!--
    Activity List Fragment Layout: Displays a scrollable list of static notifications.
    Minimal Cleanup: Added comments and localized strings without changing layout structure.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/ll_notification_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingVertical="12dp">

        <!-- Item 1: Booking Success (Warning Red Theme) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/mcv_notif_booking_success"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/primary_color"
            app:strokeWidth="1dp">

            <LinearLayout
                android:id="@+id/layout_booking_success"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="5dp"
                android:paddingVertical="10dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/iv_notif_icon_success"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_ic_circular"
                    android:backgroundTint="@color/warning_red"
                    android:padding="8dp"
                    android:src="@drawable/ic_warning_circle"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.FadeBARBer.FAB.Circle"
                    app:tint="@color/warning_red_icon" />

                <LinearLayout
                    android:id="@+id/ll_notif_content_success"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/ll_notif_header_success"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="5dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_notif_title_success"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/notif_booking_success"
                            android:textColor="@color/black"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_notif_date_success"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="05 May 26"
                            android:textColor="@color/black"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/ll_notif_body_success"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_notif_desc_success"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/notif_booking_success_desc"
                            android:textSize="12.5sp" />

                        <LinearLayout
                            android:id="@+id/ll_duration_container_success"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/iv_clock_success"
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_clock"
                                app:tint="?android:attr/textColorSecondary" />

                            <TextView
                                android:id="@+id/tv_duration_success"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="2dp"
                                android:text="@string/notif_duration_placeholder"
                                android:textColor="?android:attr/textColorSecondary"
                                android:textSize="10sp"
                                tools:text="30 Days" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Item 2: Promotion! (Success Green Theme) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/mcv_notif_promotion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/primary_color"
            app:strokeWidth="1dp">

            <LinearLayout
                android:id="@+id/layout_promotion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="5dp"
                android:paddingVertical="10dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/iv_notif_icon_promo"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_ic_circular"
                    android:backgroundTint="@color/success_green"
                    android:padding="8dp"
                    android:src="@drawable/ic_check_circle"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.FadeBARBer.FAB.Circle"
                    app:tint="@color/success_green_icon" />

                <LinearLayout
                    android:id="@+id/ll_notif_content_promo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/ll_notif_header_promo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="5dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_notif_title_promo"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/notif_promotion"
                            android:textColor="@color/black"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_notif_date_promo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="04 May 26"
                            android:textColor="@color/black"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/ll_notif_body_promo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_notif_desc_promo"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/notif_promotion_desc"
                            android:textSize="12.5sp" />

                        <LinearLayout
                            android:id="@+id/ll_duration_container_promo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/iv_clock_promo"
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_clock"
                                app:tint="?android:attr/textColorSecondary" />

                            <TextView
                                android:id="@+id/tv_duration_promo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="2dp"
                                android:text="@string/notif_duration_placeholder"
                                android:textColor="?android:attr/textColorSecondary"
                                android:textSize="10sp"
                                tools:text="30 Days" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Item 3: Reminder (Info Blue Theme) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/mcv_notif_reminder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/primary_color"
            app:strokeWidth="1dp">

            <LinearLayout
                android:id="@+id/layout_reminder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="5dp"
                android:paddingVertical="10dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/iv_notif_icon_reminder"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_ic_circular"
                    android:backgroundTint="@color/info_blue"
                    android:padding="8dp"
                    android:src="@drawable/ic_info_circle"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.FadeBARBer.FAB.Circle"
                    app:tint="@color/info_blue_icon" />

                <LinearLayout
                    android:id="@+id/ll_notif_content_reminder"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/ll_notif_header_reminder"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="5dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_notif_title_reminder"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/notif_reminder"
                            android:textColor="@color/black"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_notif_date_reminder"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="03 May 26"
                            android:textColor="@color/black"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/ll_notif_body_reminder"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_notif_desc_reminder"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/notif_reminder_desc"
                            android:textSize="12.5sp" />

                        <LinearLayout
                            android:id="@+id/ll_duration_container_reminder"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/iv_clock_reminder"
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_clock"
                                app:tint="?android:attr/textColorSecondary" />

                            <TextView
                                android:id="@+id/tv_duration_reminder"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="2dp"
                                android:text="@string/notif_duration_placeholder"
                                android:textColor="?android:attr/textColorSecondary"
                                android:textSize="10sp"
                                tools:text="30 Days" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Item 4: Profile Updated (Notification Yellow Theme) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/mcv_notif_profile_updated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/primary_color"
            app:strokeWidth="1dp">

            <LinearLayout
                android:id="@+id/layout_profile_updated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:baselineAligned="false"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="5dp"
                android:paddingVertical="10dp">

                <FrameLayout
                    android:id="@+id/fl_notif_icon_profile"
                    android:layout_width="50dp"
                    android:layout_height="50dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/iv_notif_bg_profile"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_ic_circular"
                        android:backgroundTint="@color/alert_yellow"
                        android:padding="8dp"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.FadeBARBer.FAB.Circle" />

                    <ImageView
                        android:id="@+id/iv_notif_icon_profile"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@null"
                        android:padding="13dp"
                        android:src="@drawable/ic_notification"
                        app:tint="@color/alert_yellow_icon" />
                </FrameLayout>

                <LinearLayout
                    android:id="@+id/ll_notif_content_profile"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/ll_notif_header_profile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="5dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_notif_title_profile"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/notif_profile_updated"
                            android:textColor="@color/black"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_notif_date_profile"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="02 May 26"
                            android:textColor="@color/black"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/ll_notif_body_profile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_notif_desc_profile"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/notif_profile_updated_desc"
                            android:textSize="12.5sp" />

                        <LinearLayout
                            android:id="@+id/ll_duration_container_profile"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/iv_clock_profile"
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_clock"
                                app:tint="?android:attr/textColorSecondary" />

                            <TextView
                                android:id="@+id/tv_duration_profile"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="2dp"
                                android:text="@string/notif_duration_placeholder"
                                android:textColor="?android:attr/textColorSecondary"
                                android:textSize="10sp"
                                tools:text="30 Days" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
