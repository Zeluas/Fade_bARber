<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_coordinator_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:forceDarkAllowed="false">

    <!-- Section 1: Dynamic Content Pager -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="?attr/actionBarSize"
        android:theme="@style/ViewPagerEdgeEffect" />

    <!-- Section 2: Bottom Application Bar -->
    <com.google.android.material.bottomappbar.BottomAppBar
        android:id="@+id/bottomAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:backgroundTint="@color/white"
        app:contentInsetEnd="0dp"
        app:contentInsetLeft="0dp"
        app:contentInsetRight="0dp"
        app:contentInsetStart="0dp" >

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavigation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@android:color/transparent"
            app:elevation="0dp"
            app:itemBackground="@drawable/bottom_nav_item_background"
            app:itemIconTint="@color/bottom_nav_color_state"
            app:itemTextColor="@color/bottom_nav_color_state"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/bottom_nav_menu_employee" />

    </com.google.android.material.bottomappbar.BottomAppBar>

    <!-- Section 3: Central Home Action Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="0dp"
        android:backgroundTint="@color/primary_color"
        android:src="@drawable/ic_home"
        android:contentDescription="@string/nav_home"
        app:backgroundTint="@color/black"
        app:borderWidth="0.7dp"
        app:fabCustomSize="65dp"
        app:fabSize="auto"
        app:layout_anchor="@id/bottomAppBar"
        app:layout_anchorGravity="top|center_horizontal"
        app:maxImageSize="40dp"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.FadeBARBer.FAB.Circle"
        app:tint="@color/fab_tint_selector" />

    <View
        android:id="@+id/v_fab_pill_bg"
        android:layout_width="80dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/bg_pill_primary"
        android:backgroundTint="@color/trans_primary_color"
        android:visibility="gone"
        app:layout_anchor="@id/bottomNavigation"
        app:layout_anchorGravity="center_horizontal" />

    <TextView
        android:id="@+id/tv_fab_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingTop="28dp"
        android:text="@string/nav_home"
        android:textColor="#808080"
        android:textSize="13sp"
        android:textStyle="bold"
        android:elevation="1dp"
        app:layout_anchor="@id/fab"
        app:layout_anchorGravity="bottom|center_horizontal" />

    <!-- Section 4: Exit Confirmation Dialog -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_exit_confirmation"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B3000000"
        android:clickable="true"
        android:elevation="20dp"
        android:focusable="true"
        android:visibility="gone">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/mcv_exit_dialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="40dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardPreventCornerOverlap="false"
            app:cardUseCompatPadding="false"
            app:contentPadding="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:rippleColor="#00FFFFFF">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tv_exit_dialog_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/primary_color"
                    android:gravity="center"
                    android:padding="16dp"
                    android:text="@string/exit_dialog_title"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tv_exit_dialog_msg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center"
                    android:text="@string/exit_dialog_msg"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_exit_dialog_title" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_exit_cancel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginEnd="8dp"
                    android:layout_marginBottom="24dp"
                    android:paddingVertical="12dp"
                    android:text="@string/exit_dialog_btn_cancel"
                    android:textColor="@color/primary_color"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/white"
                    app:cornerRadius="24dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/btn_exit_confirm"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_exit_dialog_msg"
                    app:rippleColor="@color/primary_color"
                    app:strokeColor="@color/primary_color"
                    app:strokeWidth="2dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_exit_confirm"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="24dp"
                    android:backgroundTint="@color/warning_red_icon"
                    android:paddingVertical="12dp"
                    android:text="@string/exit_dialog_btn_confirm"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:cornerRadius="24dp"
                    app:layout_constraintBottom_toBottomOf="@id/btn_exit_cancel"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/btn_exit_cancel"
                    app:layout_constraintTop_toTopOf="@id/btn_exit_cancel"
                    app:rippleColor="@color/trans_white" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Section 5: Logout Confirmation Overlay -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_logout_confirmation"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B3000000"
        android:clickable="true"
        android:elevation="25dp"
        android:focusable="true"
        android:visibility="gone">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/mcv_logout_dialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="false"
            android:focusable="true"
            app:cardBackgroundColor="@color/white"
            app:cardElevation="8dp"
            app:cardPreventCornerOverlap="false"
            app:cardUseCompatPadding="false"
            app:contentPadding="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:rippleColor="#00FFFFFF"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.FadeBARBer.BottomOverlay">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tv_logout_dialog_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/primary_color"
                    android:gravity="center"
                    android:padding="20dp"
                    android:text="@string/logout_confirm_title"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_logout_confirm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="24dp"
                    android:backgroundTint="@color/warning_red_icon"
                    android:paddingVertical="12dp"
                    android:text="@string/logout_confirm_btn"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:cornerRadius="24dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_logout_dialog_header"
                    app:rippleColor="@color/trans_white" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Section 6: Call Customer Overlay -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_call_customer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B3000000"
        android:clickable="true"
        android:elevation="30dp"
        android:focusable="true"
        android:visibility="gone">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/mcv_call_dialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/white"
            app:cardElevation="8dp"
            app:cardPreventCornerOverlap="false"
            app:cardUseCompatPadding="false"
            app:contentPadding="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:rippleColor="#00FFFFFF"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.FadeBARBer.BottomOverlay">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Header -->
                <TextView
                    android:id="@+id/tv_call_dialog_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/primary_color"
                    android:gravity="center"
                    android:padding="20dp"
                    android:text="Call Customer"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Customer Phone Number -->
                <TextView
                    android:id="@+id/tv_customer_phone_display"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:text="+60 12-3456 789"
                    android:textColor="@color/black"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_call_dialog_header" />

                <!-- Call Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_call_now"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="32dp"
                    android:paddingVertical="15dp"
                    android:text="Call"
                    android:textColor="@color/primary_color"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/white"
                    app:cornerRadius="24dp"
                    app:icon="@drawable/ic_phone"
                    app:iconGravity="textStart"
                    app:iconTint="@color/primary_color"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_customer_phone_display"
                    app:rippleColor="@color/trans_primary_color"
                    app:strokeColor="@color/primary_color"
                    app:strokeWidth="2dp" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Section 7: No-Show Confirmation Overlay -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_noshow_confirmation"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B3000000"
        android:clickable="true"
        android:elevation="35dp"
        android:focusable="true"
        android:visibility="gone">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/mcv_noshow_dialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="40dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardPreventCornerOverlap="false"
            app:cardUseCompatPadding="false"
            app:contentPadding="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tv_noshow_dialog_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/primary_color"
                    android:gravity="center"
                    android:padding="16dp"
                    android:text="@string/noshow_dialog_title"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tv_noshow_dialog_msg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="24dp"
                    android:gravity="center"
                    android:paddingHorizontal="12dp"
                    android:text="@string/noshow_dialog_msg"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_noshow_dialog_title" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/cb_noshow_confirm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/noshow_final_confirmation"
                    android:textColor="@color/grey_grey"
                    android:textSize="12sp"
                    app:buttonTint="@color/primary_color"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_noshow_dialog_msg" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_noshow_cancel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginEnd="8dp"
                    android:layout_marginBottom="24dp"
                    android:paddingVertical="12dp"
                    android:text="@string/noshow_dialog_btn_cancel"
                    android:textColor="@color/primary_color"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/white"
                    app:cornerRadius="24dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/btn_noshow_confirm"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/cb_noshow_confirm"
                    app:rippleColor="@color/primary_color"
                    app:strokeColor="@color/primary_color"
                    app:strokeWidth="2dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_noshow_confirm"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="24dp"
                    android:backgroundTint="@color/warning_red_icon"
                    android:paddingVertical="12dp"
                    android:text="@string/noshow_dialog_btn_confirm"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:cornerRadius="24dp"
                    app:layout_constraintBottom_toBottomOf="@id/btn_noshow_cancel"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/btn_noshow_cancel"
                    app:layout_constraintTop_toTopOf="@id/btn_noshow_cancel"
                    app:rippleColor="@color/trans_white" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Profile Image Preview Overlay -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_image_preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B3000000"
        android:clickable="true"
        android:elevation="50dp"
        android:focusable="true"
        android:visibility="gone">

        <ImageView
            android:id="@+id/iv_full_preview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="matrix" />

        <View
            android:id="@+id/v_preview_top_bar"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="#80000000"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btn_close_preview"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="5dp"
            android:layout_marginTop="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/tv_preview_title"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="10dp"
            android:gravity="center"
            android:text="Profile Picture"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/btn_close_preview"
            app:layout_constraintStart_toEndOf="@id/btn_close_preview"
            app:layout_constraintTop_toTopOf="@id/btn_close_preview" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Global Filter Overlay for Employee Book -->
    <FrameLayout
        android:id="@+id/layout_filter_overlay_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B3000000"
        android:clickable="true"
        android:elevation="60dp"
        android:focusable="true"
        android:visibility="gone">

        <include
            android:id="@+id/include_filter_overlay"
            layout="@layout/layout_filter_overlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center" />
    </FrameLayout>

    <!-- Section 8: Error Banner Overlay -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_error_banner_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/warning_red"
        android:clickable="true"
        android:elevation="70dp"
        android:focusable="true"
        android:visibility="gone">

        <!-- Radar Pulse View -->
        <View
            android:id="@+id/view_radar_pulse"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:alpha="0"
            android:background="@drawable/bg_radar_pulse"
            app:layout_constraintBottom_toBottomOf="@+id/ll_error_banner"
            app:layout_constraintEnd_toEndOf="@+id/ll_error_banner"
            app:layout_constraintStart_toStartOf="@+id/ll_error_banner"
            app:layout_constraintTop_toTopOf="@+id/ll_error_banner" />

        <LinearLayout
            android:id="@+id/ll_error_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/warning_red_icon"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_warning_circle"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/tv_error_banner_msg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/signup_error_default_msg"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
