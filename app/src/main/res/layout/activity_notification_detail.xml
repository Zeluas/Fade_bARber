<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/back_primary_color">

    <!-- Top Bar Header -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/mcv_top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="0dp"
        app:cardElevation="0dp"
        app:cardMaxElevation="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/fl_top_bar"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:background="@drawable/bg_top_bar">

            <ImageView
                android:id="@+id/iv_back_notif_detail"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center_vertical|start"
                android:layout_marginStart="5dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="Back"
                android:focusable="true"
                android:padding="12dp"
                android:src="@drawable/ic_back"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/tv_title_notif_detail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical|start"
                android:layout_marginStart="63dp"
                android:text="Notification Detail"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/mcv_top_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tv_detail_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                tools:text="Notification Title" />

            <TextView
                android:id="@+id/tv_detail_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/grey_grey"
                android:textSize="12sp"
                android:layout_marginBottom="12dp"
                tools:text="Date Placeholder" />

            <View
                android:layout_width="150dp"
                android:layout_height="4dp"
                android:background="@drawable/bg_pill_primary"
                android:layout_marginBottom="24dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/primary_color"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_detail_message"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:justificationMode="inter_word"
                        android:lineSpacingExtra="4dp"
                        android:paddingHorizontal="16dp"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        tools:text="Detailed message about the activity goes here. It can be multiple lines and will explain why this notification was sent." />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_detail_call"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:layout_marginBottom="16dp"
                        android:paddingVertical="10dp"
                        android:text="Call Hairstylist"
                        android:textColor="@color/primary_color"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:visibility="gone"
                        app:backgroundTint="@color/white"
                        app:cornerRadius="24dp"
                        app:icon="@drawable/ic_phone"
                        app:iconGravity="textStart"
                        app:iconTint="@color/primary_color"
                        app:rippleColor="@color/trans_primary_color"
                        app:strokeColor="@color/primary_color"
                        app:strokeWidth="2dp"
                        tools:visibility="visible" />

                    <!-- No-Show / Cancellation Specific Detail Container -->
                    <LinearLayout
                        android:id="@+id/ll_extra_details"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginHorizontal="16dp"
                            android:background="@color/grey_grey" />

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="12dp">

                            <TextView
                                android:id="@+id/tv_noshow_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_pill_primary"
                                android:backgroundTint="@color/warning_red_icon"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="4dp"
                                android:text="Cancelled"
                                android:textColor="@color/white"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <TextView
                                android:id="@+id/tv_noshow_booking_id"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="#FB-1024"
                                android:textColor="@color/grey_grey"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                app:layout_constraintBottom_toBottomOf="@id/tv_noshow_status"
                                app:layout_constraintStart_toEndOf="@id/tv_noshow_status"
                                app:layout_constraintTop_toTopOf="@id/tv_noshow_status" />

                            <com.google.android.material.imageview.ShapeableImageView
                                android:id="@+id/iv_noshow_hair"
                                android:layout_width="80dp"
                                android:layout_height="80dp"
                                android:layout_marginTop="12dp"
                                android:padding="1dp"
                                android:scaleType="centerCrop"
                                android:src="@drawable/ic_profile"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@id/tv_noshow_status"
                                app:shapeAppearanceOverlay="@style/ShapeAppearance.FadeBARBer.Rounded"
                                app:strokeColor="@color/black"
                                app:strokeWidth="1dp" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:orientation="vertical"
                                app:layout_constraintBottom_toBottomOf="@id/iv_noshow_hair"
                                app:layout_constraintEnd_toStartOf="@id/ll_noshow_style_info"
                                app:layout_constraintStart_toEndOf="@id/iv_noshow_hair"
                                app:layout_constraintTop_toTopOf="@id/iv_noshow_hair">

                                <TextView
                                    android:id="@+id/tv_noshow_barber"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Hairstylist Name"
                                    android:textColor="@color/black"
                                    android:textSize="18sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tv_noshow_date"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="04/05/26"
                                    android:textColor="@color/grey_grey"
                                    android:textSize="15sp" />

                                <TextView
                                    android:id="@+id/tv_noshow_time"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="10:00 AM"
                                    android:textColor="@color/primary_color"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/ll_noshow_style_info"
                                android:layout_width="90dp"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="vertical"
                                app:layout_constraintBottom_toBottomOf="@id/iv_noshow_hair"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="@id/iv_noshow_hair">

                                <FrameLayout
                                    android:layout_width="50dp"
                                    android:layout_height="50dp">

                                    <ImageView
                                        android:id="@+id/iv_noshow_hair_small"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:background="@drawable/bg_booking_hair_preview"
                                        android:padding="1dp"
                                        android:scaleType="centerCrop"
                                        android:src="@drawable/ic_hair" />
                                </FrameLayout>

                                <TextView
                                    android:id="@+id/tv_noshow_style"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:breakStrategy="simple"
                                    android:gravity="center"
                                    android:hyphenationFrequency="none"
                                    android:maxWidth="90dp"
                                    android:minWidth="60dp"
                                    android:text="Fade Cut"
                                    android:textColor="@color/black"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </LinearLayout>

                    <!-- Update Specific Detail Container (Before & After) -->
                    <LinearLayout
                        android:id="@+id/ll_update_details"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginHorizontal="16dp"
                            android:background="@color/grey_grey" />

                        <!-- Before Section -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_marginTop="12dp"
                            android:text="BEFORE UPDATE"
                            android:textColor="@color/grey_grey"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <include
                            android:id="@+id/layout_before_update"
                            layout="@layout/layout_booking_detail_mini" />

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginVertical="4dp"
                            android:rotation="180"
                            android:scaleType="center"
                            android:scaleX="3"
                            android:scaleY="3"
                            android:src="@drawable/ic_arrow_up"
                            app:tint="@color/primary_color" />

                        <!-- After Section -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="AFTER UPDATE"
                            android:textColor="@color/primary_color"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <include
                            android:id="@+id/layout_after_update"
                            layout="@layout/layout_booking_detail_mini" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_employee_reason"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="16dp"
                            android:layout_marginTop="8dp"
                            android:hint="Reason for update"
                            android:visibility="gone"
                            app:boxBackgroundColor="@color/white"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusTopStart="12dp"
                            tools:visibility="visible">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_employee_reason"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="6dp"
                                android:enabled="false"
                                android:focusable="false"
                                android:gravity="top"
                                android:inputType="textMultiLine"
                                android:maxLines="6"
                                android:minLines="3"
                                android:textColor="@color/black" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="8dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>

    <!-- Section 6: Call Hairstylist Overlay (Same as MainActivity) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_call_hairstylist"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B3000000"
        android:clickable="true"
        android:elevation="30dp"
        android:focusable="true"
        android:visibility="gone">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/mcv_call_dialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="false"
            android:focusable="true"
            app:cardBackgroundColor="@color/white"
            app:cardElevation="8dp"
            app:cardPreventCornerOverlap="false"
            app:cardUseCompatPadding="false"
            app:contentPadding="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:rippleColor="#00FFFFFF"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.FadeBARBer.BottomOverlay">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Header -->
                <TextView
                    android:id="@+id/tv_call_dialog_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/primary_color"
                    android:gravity="center"
                    android:padding="20dp"
                    android:text="Call Hairstylist"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Stylist Phone Number -->
                <TextView
                    android:id="@+id/tv_hairstylist_phone_display"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:text="+60 1234 5678 911"
                    android:textColor="@color/black"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_call_dialog_header" />

                <!-- Call Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_call_now"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="32dp"
                    android:paddingVertical="15dp"
                    android:text="Call"
                    android:textColor="@color/primary_color"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/white"
                    app:cornerRadius="24dp"
                    app:icon="@drawable/ic_phone"
                    app:iconGravity="textStart"
                    app:iconTint="@color/primary_color"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_hairstylist_phone_display"
                    app:rippleColor="@color/trans_primary_color"
                    app:strokeColor="@color/primary_color"
                    app:strokeWidth="2dp" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
