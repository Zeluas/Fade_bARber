<?xml version="1.0" encoding="utf-8"?>
<!--
    Activity Fragment Layout: Handles Inbox and Read notification tabs with a ViewPager2.
    Features:
    - Custom top bar with branding.
    - Custom tab implementation with a sliding underline animation.
    - ViewPager2 for fragment switching.
    Optimized: Reduced nesting using ConstraintLayout and localized strings.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/back_primary_color">

    <!-- Section 1: Top Bar Header -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/mcv_top_bar_activity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="0dp"
        app:cardElevation="0dp"
        app:cardMaxElevation="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/fl_top_bar_background"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:background="@drawable/bg_top_bar">

            <TextView
                android:id="@+id/tv_title_activity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical|start"
                android:layout_marginStart="12dp"
                android:text="@string/activity_title"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Section 2: Tab Navigation Container -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_tab_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="14dp"
        app:layout_constraintTop_toBottomOf="@id/mcv_top_bar_activity">

        <!-- Inbox Tab (Left) -->
        <FrameLayout
            android:id="@+id/layout_tab_inbox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@color/primary_color"
            android:clickable="true"
            android:elevation="6dp"
            android:focusable="true"
            app:layout_constraintEnd_toStartOf="@+id/layout_tab_read"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/text_tab_inbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="12dp"
                android:text="@string/activity_tab_inbox"
                android:textColor="@color/white"
                android:textStyle="bold"
                tools:text="Inbox (4)" />
        </FrameLayout>

        <!-- Read Tab (Right) -->
        <FrameLayout
            android:id="@+id/layout_tab_read"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="#208000"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/bg_inner_shadow"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@id/layout_tab_inbox"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/text_tab_read"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alpha="0.6"
                android:gravity="center"
                android:padding="12dp"
                android:text="@string/activity_tab_read"
                android:textColor="@color/white"
                android:textStyle="bold"
                tools:text="Read (0)" />
        </FrameLayout>

        <!-- Sliding Underline Background Area -->
        <View
            android:id="@+id/view_underline_bg"
            android:layout_width="0dp"
            android:layout_height="5.5dp"
            android:background="@color/trans_primary_color"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_tab_inbox" />

        <!-- Actual Sliding Underline View -->
        <View
            android:id="@+id/view_sliding_underline"
            android:layout_width="0dp"
            android:layout_height="5.5dp"
            android:background="@color/secondary_color"
            app:layout_constraintEnd_toStartOf="@+id/guideline_tab_mid"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_tab_inbox" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline_tab_mid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.5" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Section 3: Content Pager -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager_activity"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_tab_container" />

</androidx.constraintlayout.widget.ConstraintLayout>
