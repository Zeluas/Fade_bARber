<?xml version="1.0" encoding="utf-8"?>
<!--
    HomeFragment Layout:
    This layout defines the main dashboard for the user.
    It includes:
    1. A dynamic Top Bar with a floating bubble background and AI-generated jabs.
    2. A scrollable content area containing:
       - Booking Status & Current Time/Date (with dynamic themes).
       - Booking Details (Current active booking).
       - Hairstylist List (Available barbers).
       - Cut History (Past services).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/ll_home_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/back_primary_color"
    android:orientation="vertical">

    <!-- Top Bar: Contains welcome message, AI jabs, and profile picture.
         Height changes dynamically during scroll. -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/mcv_top_bar"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        app:cardBackgroundColor="@color/primary_color"
        app:cardElevation="0dp"
        app:cardMaxElevation="0dp"
        app:cardPreventCornerOverlap="false"
        app:cardUseCompatPadding="true"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.FadeBARBer.TopBar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_top_bar_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Bubble Background Animation -->
            <com.zejyv.azizul.uitm.fadebarber.FloatingBubblesView
                android:id="@+id/floating_bubbles_home"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Grey Tint Overlay for better text readability -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:background="#5E000000"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:id="@+id/ll_top_bar_text_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/iv_profile"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/tv_welcome_home"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/welcome_user"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_ai_jab"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/white"
                    android:textSize="12sp" />
            </LinearLayout>

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/iv_profile"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="16dp"
                android:background="@color/white"
                android:padding="2dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.FadeBARBer.Rounded"
                app:strokeColor="@color/black"
                app:strokeWidth="1dp" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Main Content Area: Scrollable -->
    <ScrollView
        android:id="@+id/sv_home_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/ll_home_scroll_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Row 1: Booking Status & Time/Date Widget -->
            <LinearLayout
                android:id="@+id/ll_booking_status_time_row"
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:orientation="horizontal">

                <!-- Booking Status Box -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/mcv_status_home"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:id="@+id/ll_status_box_container"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="5dp"
                            android:text="@string/booking_status_label"
                            android:textColor="@color/black"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:id="@+id/iv_status_icon"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_marginBottom="4dp"
                                android:src="@drawable/ic_calendar"
                                android:visibility="gone"
                                app:tint="@color/grey_grey" />

                            <TextView
                                android:id="@+id/tv_status_home"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="No active booking"
                                android:textColor="@color/grey_grey"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <View
                    android:layout_width="4dp"
                    android:layout_height="match_parent" />

                <!-- Time & Date Widget: Changes background and greeting based on time of day -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_datetime"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardUseCompatPadding="true">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:id="@+id/iv_time_bg"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/bg_time_sunrise" />

                        <!-- Tint Overlay for time widget -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#66000000" />

                        <LinearLayout
                            android:id="@+id/ll_datetime_overlay_container"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="8dp">

                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent">

                                <LinearLayout
                                    android:id="@+id/ll_time_date_inner"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="top|start"
                                    android:orientation="vertical">

                                    <LinearLayout
                                        android:id="@+id/ll_clock_row"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:orientation="horizontal">

                                        <TextView
                                            android:id="@+id/tv_time_home"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:textColor="@color/white"
                                            android:textSize="19sp"
                                            android:textStyle="bold"
                                            tools:text="10:00" />

                                        <TextView
                                            android:id="@+id/tv_ampm_home"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginStart="4dp"
                                            android:text="@string/am_label"
                                            android:textColor="@color/white"
                                            android:textSize="12sp"
                                            android:textStyle="bold" />
                                    </LinearLayout>

                                    <TextView
                                        android:id="@+id/tv_date_home"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textColor="@color/white"
                                        android:textSize="14sp"
                                        tools:text="12/05/24" />
                                </LinearLayout>

                                <TextView
                                    android:id="@+id/tv_time_name"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="top|end"
                                    android:layout_marginTop="4dp"
                                    android:text="@string/time_morning"
                                    android:textColor="@color/white"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tv_shop_status"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="bottom|start"
                                    android:text="@string/shop_status_open"
                                    android:textColor="@color/white"
                                    android:textSize="11sp" />
                            </FrameLayout>
                        </LinearLayout>
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Booking Details Section: Shows information about the current appointment -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:id="@+id/ll_bookingdetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/ll_booking_header"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_booking_header"
                        android:clipToPadding="false"
                        android:paddingVertical="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="@string/booking_detail_label"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/ll_booking_details_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:baselineAligned="false"
                            android:orientation="horizontal">

                            <!-- Details Column -->
                            <LinearLayout
                                android:id="@+id/ll_booking_details_left_col"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <LinearLayout
                                    android:id="@+id/ll_booking_info_labels"
                                    android:layout_width="match_parent"
                                    android:layout_height="0dp"
                                    android:layout_marginBottom="10dp"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/tv_label_date"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/date_label"
                                        android:textColor="@color/black"
                                        android:textSize="16sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:id="@+id/tv_booking_date_home"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginBottom="4dp"
                                        android:text="@string/label_placeholder"
                                        android:textSize="16sp" />

                                    <TextView
                                        android:id="@+id/tv_label_time"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="12dp"
                                        android:text="@string/time_label"
                                        android:textColor="@color/black"
                                        android:textSize="16sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:id="@+id/tv_booking_time_home"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginBottom="4dp"
                                        android:text="@string/label_placeholder"
                                        android:textSize="16sp" />

                                    <LinearLayout
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="12dp"
                                        android:gravity="center_vertical"
                                        android:orientation="horizontal">

                                        <TextView
                                            android:id="@+id/tv_label_stylist"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="@string/hairstylist_label"
                                            android:textColor="@color/black"
                                            android:textSize="16sp"
                                            android:textStyle="bold" />

                                        <com.google.android.material.button.MaterialButton
                                            android:id="@+id/btn_call_stylist"
                                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                            android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:layout_marginStart="8dp"
                                            android:background="@android:color/transparent"
                                            android:minWidth="0dp"
                                            android:minHeight="0dp"
                                            android:padding="0dp"
                                            app:backgroundTint="@android:color/transparent"
                                            app:icon="@drawable/ic_phone"
                                            app:iconPadding="0dp"
                                            app:iconSize="18dp"
                                            app:iconTint="@color/primary_color" />
                                    </LinearLayout>

                                    <TextView
                                        android:id="@+id/tv_hairstylist_name_home"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/label_placeholder"
                                        android:textSize="16sp" />
                                </LinearLayout>

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btn_cancel_booking"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginEnd="6dp"
                                    android:paddingVertical="15dp"
                                    android:text="@string/cancel_booking"
                                    android:textColor="@color/warning_red_icon"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    app:backgroundTint="#FFFFFF"
                                    app:cornerRadius="24dp"
                                    app:rippleColor="#FF7979"
                                    app:strokeColor="@color/warning_red_icon"
                                    app:strokeWidth="2dp" />

                            </LinearLayout>

                            <!-- Hairstyle Preview Column -->
                            <LinearLayout
                                android:id="@+id/ll_booking_details_right_col"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <LinearLayout
                                    android:id="@+id/ll_hair_preview_container"
                                    android:layout_width="match_parent"
                                    android:layout_height="0dp"
                                    android:layout_marginBottom="10dp"
                                    android:layout_weight="1"
                                    android:gravity="center"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/tv_label_chosen_haircut"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginBottom="4dp"
                                        android:text="@string/chosen_haircut"
                                        android:textColor="@color/black"
                                        android:textStyle="bold" />

                                    <FrameLayout
                                        android:layout_width="120dp"
                                        android:layout_height="120dp">

                                        <!-- The border and background box -->
                                        <com.google.android.material.imageview.ShapeableImageView
                                            android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:padding="2dp"
                                            android:src="@null"
                                            app:shapeAppearanceOverlay="@style/ShapeAppearance.FadeBARBer.Rounded"
                                            app:strokeColor="@color/black"
                                            app:strokeWidth="1dp" />

                                        <!-- The actual hairstyle image with pseudo padding -->
                                        <ImageView
                                            android:id="@+id/iv_hairPreview"
                                            android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:padding="12dp"
                                            android:src="@null" />
                                    </FrameLayout>

                                    <TextView
                                        android:id="@+id/tv_haircut_name_home"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="3dp"
                                        android:text="@string/haircut_name_placeholder"
                                        android:textColor="@color/black"
                                        android:textStyle="bold" />
                                </LinearLayout>

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btn_edit_booking"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="6dp"
                                    android:paddingVertical="15dp"
                                    android:text="@string/edit_booking"
                                    android:textColor="@color/white"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    app:backgroundTint="@color/primary_color"
                                    app:cornerRadius="24dp" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Session in Progress Button (Replaces Edit/Cancel buttons) -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_session_in_progress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clickable="false"
                            android:focusable="false"
                            android:paddingVertical="15dp"
                            android:text="Session in progress (00:00:00)"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:visibility="gone"
                            app:backgroundTint="@color/primary_color"
                            app:cornerRadius="24dp"
                            tools:visibility="visible" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_no_booking_placeholder"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="32dp"
                        android:text="No upcoming booking found. Schedule one now!"
                        android:textColor="@color/grey_grey"
                        android:textSize="14sp"
                        android:textStyle="italic"
                        android:visibility="visible" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Hairstylist List Section: Displays available stylists -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:id="@+id/ll_hairstylist_list_box"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/ll_hairstylist_header"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_booking_header"
                        android:paddingVertical="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="@string/hairstylist_list_label"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_stylists_home"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        tools:listitem="@layout/item_stylist_selection" />

                    <ProgressBar
                        android:id="@+id/pb_stylists_home"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_margin="16dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tv_no_stylists_home"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="16dp"
                        android:text="No stylists available."
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Cut History Section: Shows past completed bookings -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardUseCompatPadding="false">

                <LinearLayout
                    android:id="@+id/ll_cut_history_box"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_ripple_primary"
                    android:clickable="true"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:focusable="true"
                    android:orientation="vertical">

                    <!-- Cut History Header -->
                    <LinearLayout
                        android:id="@+id/ll_cut_history_header"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_booking_header"
                        android:gravity="center_vertical"
                        android:paddingVertical="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:text="@string/cut_history_label"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="12dp"
                            android:rotation="90"
                            android:src="@drawable/ic_arrow_up"
                            app:tint="@color/white" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_cut_history_home"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="8dp"
                        tools:listitem="@layout/item_cut_history" />

                    <ProgressBar
                        android:id="@+id/pb_history_home"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_margin="16dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tv_empty_history_home"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="16dp"
                        android:text="No past bookings found."
                        android:visibility="gone" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
