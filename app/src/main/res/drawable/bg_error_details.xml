<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Solid background with stroke and corners -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/warning_red" />
            <stroke
                android:width="2dp"
                android:color="@color/warning_red_icon" />
            <corners android:radius="16dp" />
        </shape>
    </item>

    <!-- Inner shadow/gradient overlay -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:centerX="50%"
                android:centerY="50%"
                android:endColor="#40000000"
                android:gradientRadius="450dp"
                android:startColor="#00000000"
                android:type="radial" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</layer-list>
