<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <gradient
                android:angle="0"
                android:endColor="@color/back_primary_color"
                android:startColor="@color/softer_primary_color"
                android:type="linear" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <item
        android:bottom="-0.5dp"
        android:left="-1dp"
        android:top="-0.5dp">
        <shape>
            <stroke
                android:width="1.5dp"
                android:color="@color/softer_primary_color" />
            <corners android:radius="12dp" />
        </shape>
    </item>
</layer-list>